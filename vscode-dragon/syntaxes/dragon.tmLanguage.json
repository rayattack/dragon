{
    "name": "Dragon",
    "scopeName": "source.dragon",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#constants" },
        { "include": "#storage-modifiers" },
        { "include": "#import-statement" },
        { "include": "#keywords" },
        { "include": "#extern-block" },
        { "include": "#self-constructor" },
        { "include": "#function-definition" },
        { "include": "#class-definition" },
        { "include": "#decorator" },
        { "include": "#type-annotation-arrow" },
        { "include": "#builtin-functions" },
        { "include": "#builtin-types" },
        { "include": "#stdlib-types" },
        { "include": "#exception-types" },
        { "include": "#template-interpolation" },
        { "include": "#self" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.dragon",
                    "begin": "\"\"\"",
                    "end": "\"\"\""
                },
                {
                    "name": "comment.line.number-sign.dragon",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.double.dragon",
                    "begin": "(f|b|r|rb|br)?\"\"\"",
                    "beginCaptures": { "1": { "name": "storage.type.string.dragon" } },
                    "end": "\"\"\""
                },
                {
                    "name": "string.quoted.triple.single.dragon",
                    "begin": "(f|b|r|rb|br)?'''",
                    "beginCaptures": { "1": { "name": "storage.type.string.dragon" } },
                    "end": "'''"
                },
                {
                    "name": "string.quoted.double.dragon",
                    "begin": "(f|b|r|rb|br)?\"",
                    "beginCaptures": { "1": { "name": "storage.type.string.dragon" } },
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.dragon",
                            "match": "\\\\."
                        },
                        {
                            "name": "meta.interpolation.dragon",
                            "begin": "(?<=f\"|f\"\"\")\\{",
                            "end": "\\}",
                            "patterns": [{ "include": "source.dragon" }]
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.dragon",
                    "begin": "(f|b|r|rb|br)?'",
                    "beginCaptures": { "1": { "name": "storage.type.string.dragon" } },
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.dragon",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.dragon",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.dragon",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.dragon",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.float.dragon",
                    "match": "\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?\\b|\\b[0-9][0-9_]*[eE][+-]?[0-9_]+\\b"
                },
                {
                    "name": "constant.numeric.integer.dragon",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.dragon",
                    "match": "\\b(True|False|None|Ellipsis|NotImplemented)\\b"
                }
            ]
        },
        "storage-modifiers": {
            "patterns": [
                {
                    "name": "storage.modifier.const.dragon",
                    "match": "\\b(const)\\b"
                },
                {
                    "name": "storage.modifier.static.dragon",
                    "match": "\\b(static)\\b"
                },
                {
                    "name": "storage.modifier.extern.dragon",
                    "match": "\\b(extern)\\b"
                }
            ]
        },
        "import-statement": {
            "patterns": [
                {
                    "comment": "from module.path import name",
                    "match": "\\b(from)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)\\s+(import)\\b",
                    "captures": {
                        "1": { "name": "keyword.control.import.dragon" },
                        "2": { "name": "entity.name.import.module.dragon" },
                        "3": { "name": "keyword.control.import.dragon" }
                    }
                },
                {
                    "comment": "import module.path",
                    "match": "\\b(import)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
                    "captures": {
                        "1": { "name": "keyword.control.import.dragon" },
                        "2": { "name": "entity.name.import.module.dragon" }
                    }
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.dragon",
                    "match": "\\b(if|elif|else|while|for|break|continue|return|pass|yield|raise|try|except|catch|finally|with)\\b"
                },
                {
                    "name": "keyword.control.import.dragon",
                    "match": "\\b(import|from|as)\\b"
                },
                {
                    "name": "keyword.control.concurrency.dragon",
                    "match": "\\b(fire|thread|async|await)\\b"
                },
                {
                    "name": "keyword.other.template.dragon",
                    "match": "\\b(template)\\b"
                },
                {
                    "name": "keyword.operator.logical.dragon",
                    "match": "\\b(and|or|not|is|in)\\b"
                },
                {
                    "name": "keyword.other.dragon",
                    "match": "\\b(def|class|lambda|global|nonlocal|assert|del)\\b"
                }
            ]
        },
        "extern-block": {
            "comment": "extern \"C\" declarations for C FFI",
            "begin": "\\b(extern)\\s+(\"C\")",
            "beginCaptures": {
                "1": { "name": "storage.modifier.extern.dragon" },
                "2": { "name": "string.quoted.double.dragon" }
            },
            "end": "(?<=\\})|(?<=;)|$",
            "patterns": [
                {
                    "name": "keyword.control.import.dragon",
                    "match": "\\b(from)\\b"
                },
                { "include": "#strings" },
                { "include": "#function-definition" },
                { "include": "#type-annotation-arrow" },
                { "include": "#builtin-types" },
                { "include": "#punctuation" }
            ]
        },
        "self-constructor": {
            "comment": "Dragon self() constructor: self(params) { ... }",
            "match": "\\b(self)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.constructor.dragon" }
            }
        },
        "function-definition": {
            "comment": "def funcname or static def funcname",
            "match": "\\b(def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.other.dragon" },
                "2": { "name": "entity.name.function.dragon" }
            }
        },
        "class-definition": {
            "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.other.dragon" },
                "2": { "name": "entity.name.type.class.dragon" }
            }
        },
        "decorator": {
            "match": "^\\s*(@)([a-zA-Z_][a-zA-Z0-9_.]*)",
            "captures": {
                "1": { "name": "punctuation.definition.decorator.dragon" },
                "2": { "name": "entity.name.function.decorator.dragon" }
            }
        },
        "type-annotation-arrow": {
            "comment": "Return type annotation: -> Type",
            "match": "(->)\\s*([a-zA-Z_][a-zA-Z0-9_\\[\\], ]*)",
            "captures": {
                "1": { "name": "punctuation.separator.arrow.dragon" },
                "2": { "name": "support.type.annotation.dragon" }
            }
        },
        "self": {
            "match": "\\b(self|cls)\\b",
            "name": "variable.language.dragon"
        },
        "builtin-functions": {
            "match": "\\b(abs|all|any|bin|bool|callable|chr|classmethod|compile|delattr|dir|divmod|enumerate|eval|exec|filter|float|format|getattr|globals|hasattr|hash|help|hex|id|input|int|isinstance|issubclass|iter|len|list|locals|map|max|min|next|object|oct|open|ord|pow|print|property|range|repr|reversed|round|set|setattr|slice|sorted|staticmethod|str|sum|super|tuple|type|vars|zip|Lock|Thread|__import__)\\s*(?=\\()",
            "captures": {
                "1": { "name": "support.function.builtin.dragon" }
            }
        },
        "builtin-types": {
            "match": "\\b(int|float|complex|bool|str|bytes|bytearray|list|tuple|set|dict|frozenset|range|object|void|ptr)\\b",
            "name": "support.type.dragon"
        },
        "stdlib-types": {
            "match": "\\b(Optional|List|Dict|Set|Tuple|Any|Union|Callable|Iterable|Iterator|Generator|Sequence|Mapping|Type|TypeVar|IO|TextIO|BinaryIO|Pattern|Match|NoReturn|Thread|SyncList|SyncDict)\\b",
            "name": "support.type.stdlib.dragon"
        },
        "exception-types": {
            "match": "\\b(BaseException|SystemExit|KeyboardInterrupt|GeneratorExit|Exception|StopIteration|ArithmeticError|ZeroDivisionError|OverflowError|FloatingPointError|AssertionError|AttributeError|BufferError|EOFError|ImportError|ModuleNotFoundError|LookupError|IndexError|KeyError|MemoryError|NameError|UnboundLocalError|OSError|FileNotFoundError|FileExistsError|PermissionError|IsADirectoryError|NotADirectoryError|InterruptedError|ProcessLookupError|TimeoutError|ConnectionError|ConnectionAbortedError|ConnectionRefusedError|ConnectionResetError|BrokenPipeError|BlockingIOError|ChildProcessError|ReferenceError|RuntimeError|NotImplementedError|RecursionError|StopAsyncIteration|SyntaxError|IndentationError|TabError|SystemError|TypeError|ValueError|UnicodeError|UnicodeDecodeError|UnicodeEncodeError|UnicodeTranslateError|Warning|UserWarning|DeprecationWarning|PendingDeprecationWarning|RuntimeWarning|SyntaxWarning|FutureWarning)\\b",
            "name": "support.type.exception.dragon"
        },
        "function-call": {
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
            "captures": {
                "1": { "name": "entity.name.function.call.dragon" }
            }
        },
        "template-interpolation": {
            "comment": "!{expr} and !{expr | filter} inside template blocks",
            "name": "meta.interpolation.template.dragon",
            "begin": "!\\{",
            "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.dragon" } },
            "end": "\\}",
            "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.dragon" } },
            "patterns": [
                {
                    "match": "\\|\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "support.function.filter.dragon" }
                    }
                },
                { "include": "source.dragon" }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.augmented.dragon",
                    "match": "\\+=|-=|\\*\\*=|\\*=|//=|/=|%=|@=|&=|\\|=|\\^=|>>=|<<="
                },
                {
                    "name": "keyword.operator.walrus.dragon",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.dragon",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.dragon",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.dragon",
                    "match": "\\*\\*|\\+|-|\\*|//|/|%|@"
                },
                {
                    "name": "keyword.operator.bitwise.dragon",
                    "match": "<<|>>|&|\\||\\^|~"
                },
                {
                    "name": "keyword.operator.arrow.dragon",
                    "match": "->"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.ellipsis.dragon",
                    "match": "\\.\\.\\."
                },
                {
                    "name": "punctuation.section.block.begin.dragon",
                    "match": "\\{"
                },
                {
                    "name": "punctuation.section.block.end.dragon",
                    "match": "\\}"
                },
                {
                    "name": "punctuation.section.parens.begin.dragon",
                    "match": "\\("
                },
                {
                    "name": "punctuation.section.parens.end.dragon",
                    "match": "\\)"
                },
                {
                    "name": "punctuation.section.brackets.begin.dragon",
                    "match": "\\["
                },
                {
                    "name": "punctuation.section.brackets.end.dragon",
                    "match": "\\]"
                },
                {
                    "name": "punctuation.separator.comma.dragon",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.colon.dragon",
                    "match": ":"
                },
                {
                    "name": "punctuation.separator.semicolon.dragon",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.dot.dragon",
                    "match": "\\."
                }
            ]
        }
    }
}
