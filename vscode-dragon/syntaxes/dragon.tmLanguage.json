        "template-html-interp": {
            "name": "meta.interpolation.template.dragon",
            "begin": "!\\{",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.interpolation.begin.dragon"
                }
            },
            "end": "\\}",
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.interpolation.end.dragon"
                }
            },
            "patterns": [
                {
                    "include": "#template-filter"
                },
                {
                    "include": "#template-html-code"
                }
            ]
        },
        "template-html": {
            "name": "meta.template.html.dragon",
            "begin": "\\b(template)\\s*(\\[)\\s*(HTML)\\s*(\\])\\s*(\\{)",
            "beginCaptures": {
                "1": {
                    "name": "keyword.other.template.dragon"
                },
                "2": {
                    "name": "punctuation.definition.template.bracket.begin.dragon"
                },
                "3": {
                    "name": "support.type.template-content.dragon"
                },
                "4": {
                    "name": "punctuation.definition.template.bracket.end.dragon"
                },
                "5": {
                    "name": "punctuation.section.template.begin.dragon"
                }
            },
            "end": "\\}",
            "endCaptures": {
                "0": {
                    "name": "punctuation.section.template.end.dragon"
                }
            },
            "contentName": "meta.embedded.block.html",
            "patterns": [
                {
                    "include": "#template-html-content"
                }
            ]
        },
