"""Behavior tests for the frames lean core (Series + DataFrame slice 1)."""

from unittest import TestCase, main
from frames import DataFrame, Series, int_series, float_series, str_series, read_csv

class FramesCoreTests(TestCase) {
    def test_construct_and_shape() {
        a: Series = int_series("a", [1, 2, 3])
        b: Series = str_series("b", ["x", "y", "z"])
        df: DataFrame = DataFrame([a, b])
        self.assertEqual(df.ncols(), 2)
        self.assertEqual(df.nrows(), 3)
        self.assertEqual("|".join(df.colnames()), "a|b")
        self.assertTrue(df.has("a"))
        self.assertFalse(df.has("zzz"))
    }

    def test_reductions_int() {
        a: Series = int_series("a", [1, 2, 3, 4])
        self.assertEqual(a.sum(), 10.0)
        self.assertEqual(a.mean(), 2.5)
        self.assertEqual(a.min(), 1.0)
        self.assertEqual(a.max(), 4.0)
        self.assertEqual(a.count(), 4)
    }

    def test_reductions_float() {
        s: Series = float_series("s", [1.0, 2.0, 3.0])
        self.assertEqual(s.sum(), 6.0)
        self.assertEqual(s.mean(), 2.0)
        self.assertEqual(s.std(), 1.0)
    }

    def test_select_and_drop() {
        a: Series = int_series("a", [1, 2])
        b: Series = int_series("b", [3, 4])
        cc: Series = int_series("c", [5, 6])
        df: DataFrame = DataFrame([a, b, cc])

        const sel: DataFrame = df.select(["a", "c"])
        self.assertEqual("|".join(sel.colnames()), "a|c")
        self.assertEqual(sel.ncols(), 2)

        const dropped: DataFrame = df.drop(["b"])
        self.assertEqual("|".join(dropped.colnames()), "a|c")
    }

    def test_filter_numeric_mask() {
        a: Series = int_series("a", [1, 2, 3, 4])
        b: Series = str_series("b", ["w", "x", "y", "z"])
        df: DataFrame = DataFrame([a, b])

        const mask: list[bool] = a.gt(2.0)
        const f: DataFrame = df.filter(mask)
        self.assertEqual(f.nrows(), 2)
        self.assertEqual(f.col("a").get_int(0), 3)
        self.assertEqual(f.col("b").get_str(1), "z")
    }

    def test_filter_str_mask() {
        a: Series = int_series("a", [1, 2, 3])
        b: Series = str_series("b", ["keep", "drop", "keep"])
        df: DataFrame = DataFrame([a, b])

        const f: DataFrame = df.filter(b.eq_str("keep"))
        self.assertEqual(f.nrows(), 2)
        self.assertEqual(f.col("a").get_int(0), 1)
        self.assertEqual(f.col("a").get_int(1), 3)
    }

    def test_read_csv_infers_dtypes() {
        const text: str = "name,age,score\nalice,30,9.5\nbob,25,8.0"
        const df: DataFrame = read_csv(text, true)
        self.assertEqual(df.ncols(), 3)
        self.assertEqual(df.nrows(), 2)
        self.assertEqual(df.col("name").dtype, 2)   # DT_STR
        self.assertEqual(df.col("age").dtype, 0)    # DT_INT
        self.assertEqual(df.col("score").dtype, 1)  # DT_FLOAT
        self.assertEqual(df.col("age").get_int(1), 25)
        self.assertEqual(df.col("score").get_float(0), 9.5)
        self.assertEqual(df.col("name").get_str(0), "alice")
    }

    def test_to_csv_roundtrip() {
        a: Series = int_series("a", [1, 2])
        b: Series = str_series("b", ["x", "y"])
        df: DataFrame = DataFrame([a, b])
        self.assertEqual(df.to_csv(), "a,b\n1,x\n2,y")
    }

    def test_sort_values_ascending_stable() {
        a: Series = int_series("a", [3, 1, 2, 1])
        b: Series = str_series("b", ["p", "q", "r", "s"])
        df: DataFrame = DataFrame([a, b])
        const s: DataFrame = df.sort_values("a", true)
        # values sorted; ties (the two 1s) keep original order q before s
        self.assertEqual(s.col("a").get_int(0), 1)
        self.assertEqual(s.col("b").get_str(0), "q")
        self.assertEqual(s.col("b").get_str(1), "s")
        self.assertEqual(s.col("a").get_int(3), 3)
    }

    def test_sort_values_descending() {
        a: Series = float_series("a", [1.5, 3.5, 2.5])
        df: DataFrame = DataFrame([a])
        const s: DataFrame = df.sort_values("a", false)
        self.assertEqual(s.col("a").get_float(0), 3.5)
        self.assertEqual(s.col("a").get_float(2), 1.5)
    }

    def test_groupby_sum_and_count() {
        city: Series = str_series("city", ["NY", "LA", "NY", "LA", "NY"])
        sales: Series = float_series("sales", [10.0, 5.0, 20.0, 7.0, 3.0])
        df: DataFrame = DataFrame([city, sales])

        const summed: DataFrame = df.groupby("city").sum("sales")
        self.assertEqual(summed.nrows(), 2)
        self.assertEqual("|".join(summed.colnames()), "city|sales")
        self.assertEqual(summed.col("city").get_str(0), "NY")
        self.assertEqual(summed.col("sales").get_float(0), 33.0)
        self.assertEqual(summed.col("sales").get_float(1), 12.0)

        const counted: DataFrame = df.groupby("city").count()
        self.assertEqual(counted.col("count").get_int(0), 3)
        self.assertEqual(counted.col("count").get_int(1), 2)
    }

    def test_groupby_mean() {
        g: Series = int_series("g", [1, 1, 2])
        v: Series = float_series("v", [2.0, 4.0, 9.0])
        df: DataFrame = DataFrame([g, v])
        const m: DataFrame = df.groupby("g").mean("v")
        self.assertEqual(m.col("v").get_float(0), 3.0)
        self.assertEqual(m.col("v").get_float(1), 9.0)
    }

    def test_inner_join() {
        lid: Series = int_series("id", [1, 2, 3])
        lname: Series = str_series("name", ["a", "b", "c"])
        left: DataFrame = DataFrame([lid, lname])

        rid: Series = int_series("id", [2, 3, 4])
        rval: Series = float_series("val", [20.0, 30.0, 40.0])
        right: DataFrame = DataFrame([rid, rval])

        const j: DataFrame = left.join(right, "id")
        self.assertEqual(j.nrows(), 2)               # ids 2 and 3 match
        self.assertEqual("|".join(j.colnames()), "id|name|val")
        self.assertEqual(j.col("id").get_int(0), 2)
        self.assertEqual(j.col("name").get_str(0), "b")
        self.assertEqual(j.col("val").get_float(1), 30.0)
    }
}

main([FramesCoreTests()])
