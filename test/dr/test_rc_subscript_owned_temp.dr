from unittest import TestCase, main


def make() -> list[int] {
    return [1, 2, 3]
}

def make_strs() -> list[str] {
    return ["aa", "bb", "cc-wwwwwwwwwwwwwwww"]
}


class Probe(TestCase) {
    def test_owned_list_receiver_int_elem() {
        i: int = 0
        while i < 3000 {
            x: int = make()[0]
            self.assertEqual(x, 1)
            i = i + 1
        }
    }

    def test_owned_list_receiver_str_elem() {
        # Element ref must be taken BEFORE the receiver temp is released
        # (use-after-free guard)
        i: int = 0
        while i < 3000 {
            s: str = make_strs()[2]
            self.assertEqual(s, "cc-wwwwwwwwwwwwwwww")
            i = i + 1
        }
    }

    def test_owned_str_receiver_slice() {
        p: str = "abcdef"
        i: int = 0
        while i < 3000 {
            s: str = ("Z" + p)[1:3]
            self.assertEqual(s, "ab")
            i = i + 1
        }
    }

    def test_owned_str_receiver_index() {
        p: str = "abcdef"
        i: int = 0
        while i < 3000 {
            c: str = ("Z" + p)[0]
            self.assertEqual(c, "Z")
            i = i + 1
        }
    }

    def test_owned_str_key() {
        d: dict[str, int] = {"kx": 7}
        p: str = "k"
        i: int = 0
        while i < 3000 {
            v: int = d[p + "x"]
            self.assertEqual(v, 7)
            i = i + 1
        }
    }

    def test_borrowed_guards() {
        # Borrowed receiver (slot) and borrowed key (slot) must NOT be
        # released - their owners still hold them.
        xs: list[int] = [9, 8, 7]
        d: dict[str, int] = {"kx": 7}
        k: str = "kx"
        i: int = 0
        while i < 3000 {
            self.assertEqual(xs[0], 9)
            self.assertEqual(d[k], 7)
            i = i + 1
        }
        self.assertEqual(xs[2], 7)
        self.assertEqual(d["kx"], 7)
    }
}


main([Probe()])
