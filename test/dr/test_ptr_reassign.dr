# Regression: reassigning a `ptr` local must not treat it as a heap string.
#
# You did nothing wrong writing ordinary code:
#
#     h: ptr = fopen(path, "r+b")
#     if not h { h = fopen(path, "w+b") }   # reassign a raw handle
#
# Codegen inferred the reassigned variable's kind from its right-hand side, and
# a `ptr`-typed value fell through to the string default. So the raw FILE* (or
# malloc buffer) was tagged a heap string, and scope cleanup ran
# dragon_decref_str over it - reading a DragonString header 16 bytes before a
# FILE*, a heap-buffer-overflow / use-after-free. A `ptr` is unmanaged; it must
# never be refcounted. Under ASan this test crashed before the fix; now clean.

from unittest import TestCase, main

extern "C" def malloc(n: int) -> ptr
extern "C" def free(p: ptr)
extern "C" def memset(s: ptr, c: intc, n: int) -> ptr
extern "C" def dragon_bytes_new(data: ptr, len: int) -> bytes


class PtrReassignTest(TestCase) {
    def test_reassigned_ptr_not_decrefed_as_string() -> None {
        a: ptr = malloc(8)
        b: ptr = malloc(8)
        p: ptr = a
        p = b                       # the trigger: reassign a raw ptr local
        memset(p, 65, 8)            # write 'A' bytes through it
        res: bytes = dragon_bytes_new(p, 8)
        free(a)
        free(b)
        self.assertEqual(len(res), 8)
        self.assertEqual(res[0], 65)
    }

    def test_conditional_ptr_reassign() -> None {
        p: ptr = malloc(4)
        if len(bytes([1])) == 1 {
            free(p)
            p = malloc(16)          # reassign inside a branch
        }
        memset(p, 7, 4)
        out: bytes = dragon_bytes_new(p, 4)
        free(p)
        self.assertEqual(out[0], 7)
    }
}


main([PtrReassignTest()])
