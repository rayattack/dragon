"""json.dumps of a list[Any] - the box-layout misread.

Given the code below:

    xs: list[Any] = [1, 2, 3]
    print(json.dumps(xs))

The result si that a `list[Any]` stores each element as a 16-byte {tag, payload} box,
a monomorphic `list[int]` stores bare 8-byte slots. Both are stamped TAG_LIST
in the tag space, and the JSON emitter cast every tag list payload to monomorphic
layout. Walking 16-byte boxes as 8-byte slots reads tag words as values:

    json.dumps([1, 2, 3] as list[Any])   -> "[0, 1, 0]"        (tags + payload)
    json.dumps(["a", "b"] as list[Any])  -> "[1, 107168755...]" (tag + raw ptr)

and runs one stride past the element region (ASan heap-buffer-overflow) ultimatey
serving garbage to whoever consumes the JSON, or crashing under a hardened allocator.

WHEN: any json.dumps whose value contains a list[Any] anywhere - a
heterogeneous array, a JSON Schema node, a dict[str, Any] holding an array.
Native (monomorphic) lists were always correct.

WHY: dispatch happened on the VALUE tag (TAG_LIST) alone, the header's type taag
(DRAGON_TAG_LIST vs DRAGON_TAG_LIST_BOX) is what distinguishes the
two layouts.

BEFORE: the values above. AFTER: the emitter dispatches on the header tag
and walks box elements as {tag, payload}, so the same code prints "[1, 2,3]" and '["a", "b"]'

One line: json.dumps now reads a list[Any] with the layout it was stored in.
"""

from unittest import TestCase, main
import json


class JsonAnyListTests(TestCase) {
    def test_int_any_list() {
        xs: list[Any] = [1, 2, 3]
        self.assertEqual(json.dumps(xs), "[1, 2, 3]")
    }

    def test_str_any_list() {
        xs: list[Any] = ["a", "b"]
        self.assertEqual(json.dumps(xs), '["a", "b"]')
    }

    def test_mixed_any_list() {
        xs: list[Any] = [1, "a", 2.5, True]
        self.assertEqual(json.dumps(xs), '[1, "a", 2.5, true]')
    }

    def test_nested_any_list() {
        xs: list[Any] = [[1, 2], ["a"]]
        self.assertEqual(json.dumps(xs), '[[1, 2], ["a"]]')
    }

    def test_any_list_inside_dict() {
        d: dict[str, Any] = {"xs": [1, 2, 3]}
        self.assertEqual(json.dumps(d), '{"xs": [1, 2, 3]}')
    }

    def test_native_list_unchanged() {
        ys: list[int] = [1, 2, 3]
        self.assertEqual(json.dumps(ys), "[1, 2, 3]")
        zs: list[str] = ["a", "b"]
        self.assertEqual(json.dumps(zs), '["a", "b"]')
    }
}


main([JsonAnyListTests()])
