from unittest import TestCase, main


def make(n: int) -> Callable[[], int] {
    return lambda () -> int { return n }
}


class SetCallableRcTests(TestCase) {
    def test_add_remove_discard_clear_churn() {
        total: int = 0
        i: int = 0
        while i < 500 {
            s: set[Callable[[], int]] = set()
            f: Callable[[], int] = make(i)
            g: Callable[[], int] = make(i + 1)
            h: Callable[[], int] = make(i + 2)
            k: Callable[[], int] = make(i + 3)
            s.add(f)
            s.add(g)
            s.add(h)
            s.add(k)
            s.remove(g)     # release path 1
            s.discard(h)    # release path 2
            if i % 2 == 0 {
                s.clear()   # release path 3; else destroy covers path 4
            }
            total = total + len(s)
            i = i + 1
        }
        # odd iterations keep 2 elements: 250 * 2
        self.assertEqual(total, 500)
    }

    def test_copy_coowns_closures() {
        # The copy must incref tag-10 elements: drop the original, collect
        # nothing, and the copy's closures must still be callable (a missing
        # incref would make this a double-free / UAF under ASan).
        s: set[Callable[[], int]] = set()
        f: Callable[[], int] = make(41)
        s.add(f)
        c: set[Callable[[], int]] = s.copy()
        s.clear()
        self.assertEqual(len(c), 1)
        self.assertEqual(f(), 41)
    }
}


main([SetCallableRcTests()])
