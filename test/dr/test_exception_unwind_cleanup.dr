# test/dr/test_exception_unwind_cleanup.dr - exception-unwind heap-local cleanup.
#
# Regression guard for the runtime cleanup stack: setjmp/longjmp unwinding skips
# the codegen scope cleanup, so owned heap locals (str, closure, container,
# instance, union) in frames a `raise` unwinds past USED to leak. The cleanup
# stack now frees exactly those locals on the longjmp arrival, mirroring the
# normal-exit decref. The tricky direction is double-free safety on the CAUGHT
# path (the catching function also frees its own locals on return) - these cases
# assert correct values + no crash; leak-freedom is verified under loop-RSS
# separately (str 189MB->1.8MB / closure 282MB->1.6MB over 3M iters, flat).

from unittest import TestCase, main


class UErr(Exception) {
    code: int
    def(c: int) { self.code = c }
}


def adder(n: int) -> Callable[[int], int] {
    def add(x: int) -> int { return x + n }
    return add
}

def count_gen(nv: int) {
    k: int = 0
    while k < nv { yield k; k = k + 1 }
}

# A `return` out of a `try` holding an owned str local - exercised via a free
# function (a TestCase method body asserting on its own `return` can't, and a
# `_`-prefixed helper method would carry protected semantics we don't want here).
def returns_from_try() -> int {
    try {
        s: str = "ret-" + str(1)
        return 99
    } except Exception {
        return -1
    }
    return 0
}

# Leaf raises; intermediate frames hold owned heap locals the longjmp skips.
def leaf() {
    raise ValueError("deep")
}
def mid(i: int) -> int {
    s: str = "midframe-" + str(i)        # owned str in an unwound frame
    f: Callable[[int], int] = adder(i)   # owned closure in an unwound frame
    leaf()
    return len(s) + f(0)
}


class ExceptionUnwindCleanupTests(TestCase) {
    # --- cross-function: callee raises through frames holding heap locals ---
    def test_cross_function_unwind() {
        caught: int = 0
        try {
            mid(5)
        } except ValueError {
            caught = 1
        }
        self.assertEqual(caught, 1)
    }

    # --- reassignment inside the try then raise: snapshot must be current,
    #  else the stale (freed) value double-frees and the new one leaks ---
    def test_reassign_in_try_then_raise() {
        got: str = "no"
        try {
            s: str = "first-" + str(1)
            s = "second-" + str(2)
            s = "third-" + str(3)
            raise ValueError("boom")
        } except ValueError {
            got = "caught"
        }
        self.assertEqual(got, "caught")
    }

    # --- raise a local instance, caught with `as e`: the handler takes the
    #  instance's +1, the unwind must NOT also free it (exc_obj exclusion) ---
    def test_raise_local_instance() {
        code: int = -1
        try {
            e: UErr = UErr(42)
            raise e
        } except UErr as caught {
            code = caught.code
        }
        self.assertEqual(code, 42)
    }

    # --- container + instance locals in the try body, caught locally ---
    def test_container_locals_caught() {
        ok: int = 0
        try {
            lst: list[int] = [1, 2, 3]
            d: dict[str, int] = {"a": 1}
            obj: UErr = UErr(7)
            raise ValueError("c")
        } except ValueError {
            ok = 1
        }
        self.assertEqual(ok, 1)
    }

    # --- union local holding a heap payload, unwound by a raise ---
    def test_union_local_unwind() {
        ok: int = 0
        try {
            u: int | str = "boxed-" + str(9)
            raise ValueError("u")
        } except ValueError {
            ok = 1
        }
        self.assertEqual(ok, 1)
    }

    # --- nested try: inner catches, outer catches; heap locals at each level ---
    def test_nested_try() {
        result: str = "no"
        try {
            outer: str = "outer-" + str(1)
            try {
                inner: str = "inner-" + str(2)
                raise ValueError("inner")
            } except ValueError {
                mid_s: str = "mid-" + str(3)
            }
            raise KeyError("outer")
        } except KeyError {
            result = "ok"
        }
        self.assertEqual(result, "ok")
    }

    # --- control flow out of a try holding a heap local (reset path) ---
    def test_break_out_of_try() {
        n: int = 0
        i: int = 0
        while i < 10 {
            try {
                s: str = "iter-" + str(i)
                if i == 3 { break }
            } except Exception {
                n = -1
            }
            n = n + 1
            i = i + 1
        }
        self.assertEqual(n, 3)
    }

    def test_return_out_of_try() {
        self.assertEqual(returns_from_try(), 99)
    }

    # --- generator object freed when a raise unwinds the for-loop frame ---
    def test_generator_loop_body_raise() {
        caught: int = 0
        try {
            for x in count_gen(5) {
                t: str = "body-" + str(x)
                if x == 3 { raise ValueError("midloop") }
            }
        } except ValueError {
            caught = 1
        }
        self.assertEqual(caught, 1)
    }
}


main([ExceptionUnwindCleanupTests()])
