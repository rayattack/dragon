# test/dr/test_secrets.dr - Behavioral tests for secrets + compare_digest.
#
# Randomness has no fixed KAT vectors, so these pin the deterministic contract:
# constant-time compare correctness, token sizes/encoding, randbelow range, and
# that the OS CSPRNG actually varies between calls. compare_digest is the
# constant-time MAC verifier - its truth table must be exact.

from unittest import TestCase, main
from secrets import token_bytes, token_hex, token_urlsafe, randbelow, randbits, compare_digest

class CompareDigestTests(TestCase) {
    def test_equal() {
        self.assertTrue(compare_digest(b"abc", b"abc"))
    }
    def test_equal_empty() {
        self.assertTrue(compare_digest(b"", b""))
    }
    def test_unequal_same_length() {
        self.assertFalse(compare_digest(b"abc", b"abd"))
    }
    def test_unequal_different_length() {
        self.assertFalse(compare_digest(b"abc", b"abcd"))
    }
}

class TokenTests(TestCase) {
    def test_token_bytes_length() {
        self.assertEqual(len(token_bytes(16)), 16)
        self.assertEqual(len(token_bytes(1)), 1)
    }
    def test_token_bytes_zero_empty() {
        self.assertEqual(len(token_bytes(0)), 0)
    }
    def test_token_hex_length() {
        # hex is two chars per byte
        self.assertEqual(len(token_hex(16)), 32)
    }
    def test_token_urlsafe_no_padding() {
        s: str = token_urlsafe(16)
        self.assertGreater(len(s), 0)
        self.assertNotIn("=", s)
    }
    def test_urandom_varies() {
        # Two CSPRNG draws of 32 bytes must differ (collision prob ~2^-256).
        a: bytes = token_bytes(32)
        b: bytes = token_bytes(32)
        self.assertNotEqual(a, b)
    }
}

class RandbelowTests(TestCase) {
    def test_range_and_not_stuck() {
        seen: set[int] = set()
        i: int = 0
        while i < 200 {
            v: int = randbelow(100)
            self.assertGreaterEqual(v, 0)
            self.assertLess(v, 100)
            seen.add(v)
            i = i + 1
        }
        # Astronomically unlikely (100^-199) to draw a single value 200 times.
        self.assertGreater(len(seen), 1)
    }
    def test_randbelow_one_is_zero() {
        i: int = 0
        while i < 20 {
            self.assertEqual(randbelow(1), 0)
            i = i + 1
        }
    }
    def test_randbits_range() {
        i: int = 0
        while i < 100 {
            v: int = randbits(8)
            self.assertGreaterEqual(v, 0)
            self.assertLess(v, 256)
            i = i + 1
        }
    }
    def test_randbits_zero() {
        self.assertEqual(randbits(0), 0)
    }
}

main([CompareDigestTests(), TokenTests(), RandbelowTests()])
