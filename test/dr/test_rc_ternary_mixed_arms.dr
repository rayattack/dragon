from unittest import TestCase, main

def consume(s: str) -> bool {
    return len(s) > 0
}

class TernaryMixedArmsRC(TestCase) {
    def test_dict_read_vs_literal_arm() {
        d: dict[str, str] = {}
        d["content-type"] = "x" + "text/plain; charset=utf-8"
        i: int = 0
        while i < 2000 {
            ok: bool = consume(d["content-type"] if "content-type" in d else "")
            self.assertTrue(ok)
            i = i + 1
        }
        # The dict's stored value survives all evaluations (no over-drain)
        self.assertEqual(d["content-type"], "xtext/plain; charset=utf-8")
    }

    def test_borrowed_name_arms() {
        a: str = "left" + "L"
        b: str = "right" + "R"
        i: int = 0
        while i < 2000 {
            picked: str = a if i % 2 == 0 else b
            self.assertTrue(len(picked) > 4)
            i = i + 1
        }
        self.assertEqual(a, "leftL")
        self.assertEqual(b, "rightR")
    }

    def test_owned_call_arms() {
        i: int = 0
        while i < 2000 {
            v: str = ("a" + str(i)) if i % 2 == 0 else ("b" + str(i))
            self.assertTrue(len(v) > 1)
            i = i + 1
        }
    }
}

main([TernaryMixedArmsRC()])
