"""Generic-method call as a bare reassignment RHS.

Given the code:

    const a: int = db.val[int]("SELECT 1")   # compiles
    x = db.val[int]("SELECT 2")              # ERROR: type 'Connection' has
                                             #        no attribute 'val[int]'

The declaration form worked; the plain reassignment of an existing variable
failed on the SAME call. Checking `recv.method[T](args)` stamps a concrete
specialization and retargets the call node to its stamped name
(`val[int]`). A declaration infers its RHS once, but a bare reassignment
infers the RHS AGAIN to validate it against the slot's declared type - and
the second look saw the already-retargeted node, fell through to ordinary
attribute dispatch, and reported the stamped name as a missing attribute.

WHEN: any reassignment (or re-checked pass) whose RHS calls a generic
method - the db.val[T]/one[T]/all[T] fetch surface being the everyday case.

WHY: IT appears the revisit guard recognised retargeted FREE functions but not
retargeted METHODS e.g. (an AttributeExpr attribute containing '[').

BEFORE: `x = r.cast[int](42)` was a compile error. AFTER: it compiles and
returns the right value; declaration behavior unchanged.

One line: a stamped generic-method call now survives being type-checked
twice.
"""

from unittest import TestCase, main


class Repo {
    def cast[T](x: T) -> T {
        return x
    }
}


class OtherRepo {
    # Same method name and shape on a DIFFERENT class: its stamp must not
    # collide with Repo's in the re-visit return-type record.
    def cast[T](x: T) -> T {
        return x
    }
}


class SubRepo(Repo) {
    def tag() -> str {
        return "sub"
    }
}


class GenericMethodReassignTests(TestCase) {
    def test_explicit_stamp_on_reassignment() {
        const r: Repo = Repo()
        x: int = 0
        x = r.cast[int](42)
        self.assertEqual(x, 42)
        s: str = ""
        s = r.cast[str]("hi")
        self.assertEqual(s, "hi")
    }

    def test_inferred_stamp_on_reassignment() {
        const r: Repo = Repo()
        x: int = 0
        x = r.cast(7)
        self.assertEqual(x, 7)
    }

    def test_reassignment_in_loop_revisits() {
        # The same call node is re-checked repeatedly; every visit after
        # the first sees the retargeted stamped name.
        const r: Repo = Repo()
        acc: int = 0
        i: int = 0
        while i < 5 {
            acc = acc + r.cast[int](i)
            i = i + 1
        }
        self.assertEqual(acc, 10)
    }

    def test_inherited_generic_method_reassignment() {
        const s: SubRepo = SubRepo()
        x: int = 0
        x = s.cast[int](9)
        self.assertEqual(x, 9)
        self.assertEqual(s.tag(), "sub")
    }

    def test_same_named_stamps_do_not_collide() {
        const a: Repo = Repo()
        const b: OtherRepo = OtherRepo()
        x: int = 0
        x = a.cast[int](1)
        y: int = 0
        y = b.cast[int](2)
        self.assertEqual(x, 1)
        self.assertEqual(y, 2)
    }

    def test_declaration_form_still_works() {
        const r: Repo = Repo()
        const a: int = r.cast[int](41)
        self.assertEqual(a, 41)
    }
}


main([GenericMethodReassignTests()])
