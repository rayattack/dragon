from unittest import TestCase, main
from threading import Lock


class WithBox {
    # E15 (docs/002 2.10): a Lock field must be declared own - a raw mutex
    # has no refcount, so a non-own Lock field has no owner to destroy it.
    own _lock: Lock

    def() {
        self._lock = Lock()
        self._d: dict[str, int] = {}
    }

    def put(k: str, v: int) -> None {
        with self._lock {
            self._d[k] = v
        }
    }

    def size() -> int {
        with self._lock {
            return len(self._d)
        }
    }
}


class AcquireBox {
    own _lock: Lock

    def() {
        self._lock = Lock()
        self._d: dict[str, int] = {}
    }

    def put(k: str, v: int) -> None {
        self._lock.acquire()
        self._d[k] = v
        self._lock.release()
    }

    def size() -> int {
        self._lock.acquire()
        const n: int = len(self._d)
        self._lock.release()
        return n
    }
}


const WB: WithBox = WithBox()
const AB: AcquireBox = AcquireBox()


def with_worker(prefix: str) -> None {
    i: int = 0
    while i < 5000 {
        WB.put(prefix + str(i), i)
        i = i + 1
    }
}


def acquire_worker(prefix: str) -> None {
    i: int = 0
    while i < 5000 {
        AB.put(prefix + str(i), i)
        i = i + 1
    }
}


class LockFieldTests(TestCase) {
    def test_with_field_lock_serializes_parallel_mutation() {
        t1: Task = fire with_worker("a")
        t2: Task = fire with_worker("b")
        t1.join()
        t2.join()
        # 2 workers x 5000 unique keys: exact only if the lock really locks
        # (an unlocked overlap corrupts the dict or trips the detector).
        self.assertEqual(WB.size(), 10000)
    }

    def test_explicit_field_acquire_release_serializes() {
        t1: Task = fire acquire_worker("a")
        t2: Task = fire acquire_worker("b")
        t1.join()
        t2.join()
        self.assertEqual(AB.size(), 10000)
    }
}


main([LockFieldTests()])
