"""json.compile / Schema.validate - the stdlib JSON Schema validation engine.

Compile once, validate many:

    const schema: Schema = json.compile('{"type": "object", "required": ["id"]}')
    const result: ValidationResult = schema.validate(json.loads(body))
    if not result.ok {
        for e in result.errors { print(f"{e.path}: {e.message}") }
    }

Covers the supported Draft-7 subset (type incl. type lists, enum with deep
equality, required/properties, items/minItems/maxItems, minLength/maxLength,
minimum/maximum), the named registry (json.register / json.validate), and
literal-built schemas via compile_obj (nested literals in Any slots are born
in the box representation - see test_list_repr_views.dr).
"""

from unittest import TestCase, main
import json
from json import Schema, ValidationResult, ValidationError, kind_of


class TestKinds(TestCase) {
    def test_kind_of_json_values() -> None {
        const doc: dict[str, Any] = json.loads_obj('{"s":"hi","i":42,"f":1.5,"b":true,"a":[1],"o":{"k":1},"n":null}')
        self.assertEqual(kind_of(doc["s"]), "string")
        self.assertEqual(kind_of(doc["i"]), "integer")
        self.assertEqual(kind_of(doc["f"]), "number")
        self.assertEqual(kind_of(doc["b"]), "boolean")
        self.assertEqual(kind_of(doc["a"]), "array")
        self.assertEqual(kind_of(doc["o"]), "object")
        self.assertEqual(kind_of(doc["n"]), "null")
    }
}


class TestTypeKeyword(TestCase) {
    def test_object_accepts_object() -> None {
        const s: Schema = json.compile('{"type": "object"}')
        self.assertEqual(s.validate(json.loads('{"a": 1}')).ok, True)
    }

    def test_object_rejects_array_with_path() -> None {
        const s: Schema = json.compile('{"type": "object"}')
        const r: ValidationResult = s.validate(json.loads('[1, 2]'))
        self.assertEqual(r.ok, False)
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$")
        self.assertEqual(r.errors[0].message, "expected object, got array")
    }

    def test_number_accepts_integer() -> None {
        const s: Schema = json.compile('{"type": "number"}')
        self.assertEqual(s.validate(json.loads('3')).ok, True)
        self.assertEqual(s.validate(json.loads('3.5')).ok, True)
    }

    def test_integer_rejects_fraction_and_bool() -> None {
        const s: Schema = json.compile('{"type": "integer"}')
        self.assertEqual(s.validate(json.loads('3.5')).ok, False)
        self.assertEqual(s.validate(json.loads('true')).ok, False)
    }

    def test_type_union_list() -> None {
        const s: Schema = json.compile('{"type": ["string", "null"]}')
        self.assertEqual(s.validate(json.loads('"x"')).ok, True)
        self.assertEqual(s.validate(json.loads('null')).ok, True)
        self.assertEqual(s.validate(json.loads('7')).ok, False)
    }
}


class TestObjectAndArray(TestCase) {
    def test_required_missing_path() -> None {
        const s: Schema = json.compile('{"type": "object", "required": ["order", "qty"]}')
        const r: ValidationResult = s.validate(json.loads('{"order": "o-1"}'))
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$.qty")
        self.assertEqual(r.errors[0].message, "required property missing")
    }

    def test_properties_recurse() -> None {
        const s: Schema = json.compile('{"type": "object", "properties": {"qty": {"type": "integer", "minimum": 1}}}')
        self.assertEqual(s.validate(json.loads('{"qty": 2}')).ok, True)
        const r: ValidationResult = s.validate(json.loads('{"qty": 0}'))
        self.assertEqual(r.errors[0].path, "$.qty")
        self.assertEqual(r.errors[0].message, "value below minimum")
    }

    def test_absent_optional_property_ok() -> None {
        const s: Schema = json.compile('{"type": "object", "properties": {"qty": {"type": "integer"}}}')
        self.assertEqual(s.validate(json.loads('{}')).ok, True)
    }

    def test_items_recurse_with_paths() -> None {
        const s: Schema = json.compile('{"type": "array", "items": {"type": "integer"}}')
        self.assertEqual(s.validate(json.loads('[1, 2, 3]')).ok, True)
        const r: ValidationResult = s.validate(json.loads('[1, "x", 3]'))
        self.assertEqual(len(r.errors), 1)
        self.assertEqual(r.errors[0].path, "$[1]")
        self.assertEqual(r.errors[0].message, "expected integer, got string")
    }

    def test_min_max_items() -> None {
        const s: Schema = json.compile('{"type": "array", "minItems": 1, "maxItems": 2}')
        self.assertEqual(s.validate(json.loads('[]')).ok, False)
        self.assertEqual(s.validate(json.loads('[1]')).ok, True)
        self.assertEqual(s.validate(json.loads('[1, 2, 3]')).ok, False)
    }
}


class TestScalarKeywords(TestCase) {
    def test_string_length_bounds() -> None {
        const s: Schema = json.compile('{"type": "string", "minLength": 2, "maxLength": 4}')
        self.assertEqual(s.validate(json.loads('"a"')).ok, False)
        self.assertEqual(s.validate(json.loads('"ab"')).ok, True)
        self.assertEqual(s.validate(json.loads('"abcde"')).ok, False)
    }

    def test_numeric_bounds_cross_kind() -> None {
        const s: Schema = json.compile('{"minimum": 1.5, "maximum": 10}')
        self.assertEqual(s.validate(json.loads('1')).ok, False)
        self.assertEqual(s.validate(json.loads('2')).ok, True)
        self.assertEqual(s.validate(json.loads('10.5')).ok, False)
    }

    def test_enum_scalars() -> None {
        const s: Schema = json.compile('{"enum": ["red", "green", 3, true, null]}')
        self.assertEqual(s.validate(json.loads('"green"')).ok, True)
        self.assertEqual(s.validate(json.loads('3')).ok, True)
        self.assertEqual(s.validate(json.loads('true')).ok, True)
        self.assertEqual(s.validate(json.loads('null')).ok, True)
        self.assertEqual(s.validate(json.loads('"blue"')).ok, False)
        self.assertEqual(s.validate(json.loads('3.0')).ok, False)
        self.assertEqual(s.validate(json.loads('false')).ok, False)
    }

    def test_enum_deep_values() -> None {
        const s: Schema = json.compile('{"enum": [[1, 2], {"a": 1}]}')
        self.assertEqual(s.validate(json.loads('[1, 2]')).ok, True)
        self.assertEqual(s.validate(json.loads('{"a": 1}')).ok, True)
        self.assertEqual(s.validate(json.loads('[1, 3]')).ok, False)
        self.assertEqual(s.validate(json.loads('{"a": 2}')).ok, False)
        self.assertEqual(s.validate(json.loads('{"b": 1}')).ok, False)
    }
}


class TestLiteralBuiltSchema(TestCase) {
    def test_compile_obj_literal_schema() -> None {
        # a schema built as a Dragon literal (nested list in an Any slot is
        # born boxed - the compiler fix this engine depends on)
        const doc: dict[str, Any] = {"type": "object", "required": ["order"], "properties": {"order": {"type": "integer", "minimum": 1}}}
        const s: Schema = json.compile_obj(doc)
        self.assertEqual(s.validate(json.loads('{"order": 2}')).ok, True)
        self.assertEqual(s.validate(json.loads('{"order": 0}')).ok, False)
        self.assertEqual(s.validate(json.loads('{}')).ok, False)
    }
}


class TestRegistry(TestCase) {
    def test_register_and_validate_by_name() -> None {
        json.register("order.placed", '{"type": "object", "required": ["order"], "properties": {"order": {"type": "integer"}}}')
        self.assertEqual(json.registered("order.placed"), True)
        self.assertEqual(json.registered("order.cancelled"), False)
        self.assertEqual(json.validate("order.placed", json.loads('{"order": 7}')).ok, True)
        const r: ValidationResult = json.validate("order.placed", json.loads('{"order": "x"}'))
        self.assertEqual(r.ok, False)
        self.assertEqual(r.errors[0].path, "$.order")
    }
}


class TestRealWorldShape(TestCase) {
    def test_amebo_order_schema() -> None {
        const s: Schema = json.compile('{"type": "object", "required": ["order", "items"], "properties": {"order": {"type": "string", "minLength": 1}, "items": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["sku", "qty"], "properties": {"sku": {"type": "string"}, "qty": {"type": "integer", "minimum": 1}}}}}}')
        self.assertEqual(s.validate(json.loads('{"order": "ord-9", "items": [{"sku": "tea", "qty": 2}]}')).ok, True)

        const r: ValidationResult = s.validate(json.loads('{"order": "", "items": [{"sku": "tea", "qty": 0}, {"sku": 5}]}'))
        self.assertEqual(len(r.errors), 4)
        self.assertEqual(r.errors[0].path, "$.order")
        self.assertEqual(r.errors[0].message, "string shorter than minLength 1")
        self.assertEqual(r.errors[1].path, "$.items[0].qty")
        self.assertEqual(r.errors[1].message, "value below minimum")
        self.assertEqual(r.errors[2].path, "$.items[1].qty")
        self.assertEqual(r.errors[2].message, "required property missing")
        self.assertEqual(r.errors[3].path, "$.items[1].sku")
        self.assertEqual(r.errors[3].message, "expected string, got integer")
    }
}


main([TestKinds(), TestTypeKeyword(), TestObjectAndArray(), TestScalarKeywords(), TestLiteralBuiltSchema(), TestRegistry(), TestRealWorldShape()])
