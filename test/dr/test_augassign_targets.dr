"""Augmented assignment to subscript and attribute targets.

Regression for the silent-no-op bug: `visit(AugAssignStmt)` only fully handled
NameExpr targets and a slice of dict/list element targets, so the rest of
`d[k] OP= v`, `lst[i] OP= v`, and `obj.field OP= v` silently did nothing (a
wrong-answer bug - no error, value unchanged). Also covers the float `//`/`%`
base operators, which previously crashed the compiler (ICmp on f64 operands).

Cases here were each reproduced as no-ops before the fix; the working controls
(str-keyed int dict, list[int], instance int field) guard against regressions.
"""

from unittest import TestCase, main

# Helper classes are defined BEFORE the TestCase that uses them: a class
# referenced before its definition (forward reference) is a separate, pre-existing
# codegen bug (field access no-ops entirely - longhand and numeric alike), unrelated
# to aug-assign.
class StrBuf {
    def() {
        self.s: str = ""
    }
    def add(x: str) {
        self.s += x
    }
}

class ByteBuf {
    def() {
        self.data: bytes = bytes()
    }
    def update(more: bytes) {
        self.data += more
    }
}

class IntKeyedDictAug(TestCase) {
    def test_int_key_int_value_all_ops() {
        d: dict[int, int] = {5: 100}
        d[5] += 10
        self.assertEqual(d[5], 110)
        d[5] -= 30
        self.assertEqual(d[5], 80)
        d[5] *= 2
        self.assertEqual(d[5], 160)
        d[5] //= 3
        self.assertEqual(d[5], 53)
        d[5] %= 10
        self.assertEqual(d[5], 3)
        d[5] <<= 4
        self.assertEqual(d[5], 48)
    }

    def test_int_key_float_value() {
        d: dict[int, float] = {1: 1.5}
        d[1] += 2.0
        self.assertAlmostEqual(d[1], 3.5)
        d[1] /= 2.0
        self.assertAlmostEqual(d[1], 1.75)
    }

    def test_int_key_str_value_concat() {
        d: dict[int, str] = {1: "a"}
        d[1] += "bc"
        self.assertEqual(d[1], "abc")
    }
}

class StrKeyedDictAug(TestCase) {
    def test_str_key_int_control() {
        d: dict[str, int] = {"a": 10}
        d["a"] += 5
        self.assertEqual(d["a"], 15)
    }

    def test_str_key_str_concat() {
        d: dict[str, str] = {"k": "x"}
        d["k"] += "y"
        d["k"] += "z"
        self.assertEqual(d["k"], "xyz")
    }

    def test_str_key_bytes_concat() {
        d: dict[str, bytes] = {"k": bytes([1])}
        d["k"] += bytes([2, 3])
        self.assertEqual(len(d["k"]), 3)
    }

    def test_str_key_float_floor_mod() {
        d: dict[str, float] = {"a": 7.0}
        d["a"] //= 2.0
        self.assertAlmostEqual(d["a"], 3.0)
        d["a"] = 7.0
        d["a"] %= 2.0
        self.assertAlmostEqual(d["a"], 1.0)
    }
}

class ListElementAug(TestCase) {
    def test_int_control_and_floordiv_mod() {
        l: list[int] = [100]
        l[0] += 5
        self.assertEqual(l[0], 105)
        l[0] //= 4
        self.assertEqual(l[0], 26)
        l[0] %= 5
        self.assertEqual(l[0], 1)
    }

    def test_float_floor_mod() {
        l: list[float] = [7.5]
        l[0] //= 2.0
        self.assertAlmostEqual(l[0], 3.0)
    }

    def test_str_concat() {
        l: list[str] = ["x"]
        l[0] += "y"
        self.assertEqual(l[0], "xy")
    }

    def test_bytes_concat() {
        l: list[bytes] = [bytes([1])]
        l[0] += bytes([2, 3])
        self.assertEqual(len(l[0]), 3)
    }
}

class CounterStatic {
    static total: int = 0
    static sum: float = 0.0
}

class FieldAug(TestCase) {
    def test_static_int_field() {
        CounterStatic.total += 3
        CounterStatic.total += 4
        self.assertEqual(CounterStatic.total, 7)
    }

    def test_static_float_field() {
        CounterStatic.sum += 2.5
        CounterStatic.sum *= 4.0
        self.assertAlmostEqual(CounterStatic.sum, 10.0)
    }

    def test_instance_str_field_concat() {
        b: StrBuf = StrBuf()
        b.add("ab")
        b.add("cd")
        self.assertEqual(b.s, "abcd")
    }

    def test_instance_bytes_field_concat() {
        h: ByteBuf = ByteBuf()
        h.update(bytes([1, 2]))
        h.update(bytes([3]))
        self.assertEqual(len(h.data), 3)
    }

    def test_str_field_accumulate_loop() {
        # RC stress: 500 overwrite-decrefs must stay balanced (no crash) + correct.
        b: StrBuf = StrBuf()
        i: int = 0
        while i < 500 {
            b.add("xy")
            i = i + 1
        }
        self.assertEqual(len(b.s), 1000)
    }
}

# StrBuf / ByteBuf are defined at the top of this file (before FieldAug) - a
# forward reference would hit a separate pre-existing codegen bug.
main([IntKeyedDictAug(), StrKeyedDictAug(), ListElementAug(), FieldAug()])
