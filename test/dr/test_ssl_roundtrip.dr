const VALID_KEY_PEM: str = """-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIMSgVF/NzvMlaJ2xWkLzyNVz1K/tHeFlgPiEip8FfmgXoAoGCCqGSM49
