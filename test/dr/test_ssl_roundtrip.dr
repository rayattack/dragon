"""

const EXPIRED_CERT_PEM: str = """-----BEGIN CERTIFICATE-----
MIIBrDCCAVOgAwIBAgICEAAwCgYIKoZIzj0EAwIwGTEXMBUGA1UEAwwORHJhZ29u
IFRlc3QgQ0EwHhcNMTkwMTAxMDAwMDAwWhcNMjAwMTAxMDAwMDAwWjAUMRIwEAYD
VQQDDAlsb2NhbGhvc3QwWTATBgcqhkjOPQIBBggqhkjOPQMBBwNCAASc+j6wkhgV
BSPMcrjFt9jw8VPy7G8/A1PKdj0z2VPAuV4Mn16N6/hpo7Rjtz/Iwj7tgEb+jxZl
l0tsj7ULh9gco4GPMIGMMAkGA1UdEwQCMAAwDgYDVR0PAQH/BAQDAgeAMBMGA1Ud
JQQMMAoGCCsGAQUFBwMBMBoGA1UdEQQTMBGCCWxvY2FsaG9zdIcEfwAAATAdBgNV
HQ4EFgQUCOtbWpipJlcpjqft1bp+S3CFjs0wHwYDVR0jBBgwFoAU9MbZafuQL+Ir
