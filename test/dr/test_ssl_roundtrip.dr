# test/dr/test_ssl_roundtrip.dr - live TLS over loopback (ADR 038, Phase 6).
#
# Exercises the real handshake end-to-end: a server presents a cert on a
# dedicated OS thread (threading.Thread) while the client connects on the main
# thread. Per ADR 038 §8 the v1 I/O model is "blocking on blocking fds", so the
# two endpoints MUST run on separate OS threads - a green thread (`fire`) would
# block its scheduler carrier, and `thread { }` joins at block exit (synchronous,
# so the server's accept() would deadlock the client). A manual Thread is the
# right tier here.
#
# Fixtures are embedded ECDSA P-256 PEM (an in-policy curve), materialized to
# temp files because mbedTLS's cert/key loaders take file paths. They are:
#  - a test CA (valid 2026..2126),
#  - a leaf for CN/SAN=localhost,127.0.0.1 chained to the CA (valid 100y),
#  - an expired leaf (notAfter 2020) chained to the CA.
# This keeps the suite self-contained and offline - no openssl at test time.
#
# Covered: happy-path round-trip + peer-verified; and the three cert-verify
# negatives (untrusted chain, hostname mismatch, expired cert) each asserting
# SSLCertVerificationError, mirroring CPython's ssl negative tests.

from unittest import TestCase, main
from socket import TcpListener, TcpStream
from ssl import SSLContext, SSLSocket, SSLCertVerificationError
from ssl import PROTOCOL_TLS_CLIENT, PROTOCOL_TLS_SERVER
from threading import Thread
from io import make
from tempfile import mktemp
from time import monotonic


def _materialize(pem: str, suffix: str) -> str {
    const path: str = mktemp("dragon_tls_", suffix)
    with make(path) as w {
        w.write(pem)
    }
    return path
}


#===----------------------------------------------------------------------===#
# Embedded fixtures (ECDSA P-256). See file header for what each is.
#===----------------------------------------------------------------------===#

const CA_PEM: str = """-----BEGIN CERTIFICATE-----
MIIBmjCCAT+gAwIBAgIUBZMgeHUPsiIZRdPawrSBNFUF4akwCgYIKoZIzj0EAwIw
GTEXMBUGA1UEAwwORHJhZ29uIFRlc3QgQ0EwIBcNMjYwNTI0MDE0MTE0WhgPMjEy
NjA0MzAwMTQxMTRaMBkxFzAVBgNVBAMMDkRyYWdvbiBUZXN0IENBMFkwEwYHKoZI
zj0CAQYIKoZIzj0DAQcDQgAEVXXFl+C9jHMfQlOj2k50xUE7m+KT0PPKDZblL8J9
lQqX4Bgocbg+M2VJGxQZY4JpVPszSIv4hVNZstxiSgO0EaNjMGEwHQYDVR0OBBYE
FPTG2Wn7kC/iKw/Xxo5v8K5JwjJQMB8GA1UdIwQYMBaAFPTG2Wn7kC/iKw/Xxo5v
8K5JwjJQMA8GA1UdEwEB/wQFMAMBAf8wDgYDVR0PAQH/BAQDAgEGMAoGCCqGSM49
