4cLMdLQQUoS3H35KDhwCIEmunCv1UP2aor8gCGOLLcFg/HnGcfySQ3x0OtDWATqO
-----END CERTIFICATE-----
"""

const EXPIRED_KEY_PEM: str = """-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIMGKvqbmOhhNHnA0h8dqTwoMHD6u2zWy8qt6ty3bBNHRoAoGCCqGSM49
AwEHoUQDQgAEnPo+sJIYFQUjzHK4xbfY8PFT8uxvPwNTynY9M9lTwLleDJ9ejev4
aaO0Y7c/yMI+7YBG/o8WZZdLbI+1C4fYHA==
-----END EC PRIVATE KEY-----
"""

# Temp paths the cert material is written to (mbedTLS loaders take file paths).
const ca_file: str = _materialize(CA_PEM, ".crt")
const valid_cert_file: str = _materialize(VALID_CERT_PEM, ".crt")
const valid_key_file: str = _materialize(VALID_KEY_PEM, ".key")
const expired_cert_file: str = _materialize(EXPIRED_CERT_PEM, ".crt")
const expired_key_file: str = _materialize(EXPIRED_KEY_PEM, ".key")

const SERVER_REPLY: str = "HELLO-FROM-DRAGON-TLS"
const PORT: int = 19443

# One listener, bound once, shared across the sequential tests. Each test starts
# a one-shot server thread that does exactly one accept; tests join before
# returning, so only one connection is in flight at a time.
const g_listener: TcpListener = TcpListener("127.0.0.1", PORT)


#===----------------------------------------------------------------------===#
# Server side - runs on a dedicated OS thread (no-arg Thread target).
#===----------------------------------------------------------------------===#

# Accept one connection, present `certfile`/`keyfile`, echo a fixed reply. A
# handshake that the client rejects fails here too (the client sends a fatal
# alert); that is expected for the negative tests, so it is swallowed rather
# than crashing the thread.
def _serve_once(certfile: str, keyfile: str) -> None {
    try {
        const conn: TcpStream = g_listener.do_accept()
        const sctx: SSLContext = SSLContext(PROTOCOL_TLS_SERVER)
        sctx.load_cert_chain(certfile, keyfile)
        const tls: SSLSocket = sctx.wrap_socket(conn, True, "")
        const req: bytes = tls.recv(4096)
        tls.send(SERVER_REPLY)
        tls.close()
    } except Exception {
        # Negative tests intentionally make the handshake fail here.
    }
}

def server_valid() -> int {
    _serve_once(valid_cert_file, valid_key_file)
    return 0
}

def server_expired() -> int {
    _serve_once(expired_cert_file, expired_key_file)
    return 0
}

# R1: a TLS read must be bounded by an idle timeout, so a peer that handshakes
# then goes silent is dropped instead of pinning the server. Captures whether
# do_recv_timeout returned empty (timeout) and how long it waited; read after
# join(). Runs on a real OS thread, so it exercises the off-vthread bounded-poll
# fallback path of the TLS recv timeout.
class _TlsProbe {
    timed_out: bool
    elapsed_ms: float
    def() {
        self.timed_out = false
        self.elapsed_ms = 0.0
    }
}
const g_probe: _TlsProbe = _TlsProbe()

def server_recv_timeout() -> int {
    try {
        const conn: TcpStream = g_listener.do_accept()
        const sctx: SSLContext = SSLContext(PROTOCOL_TLS_SERVER)
        sctx.load_cert_chain(valid_cert_file, valid_key_file)
        const tls: SSLSocket = sctx.wrap_socket(conn, True, "")
        const t0: float = monotonic()
        const data: str = tls.do_recv_timeout(4096, 300)
        const t1: float = monotonic()
        g_probe.elapsed_ms = (t1 - t0) * 1000.0
        g_probe.timed_out = len(data) == 0
        tls.close()
    } except Exception {
    }
    return 0
}


g_listener.do_bind()
g_listener.do_listen(16)


#===----------------------------------------------------------------------===#
# Tests
#===----------------------------------------------------------------------===#

class TlsLoopbackTests(TestCase) {
    # Happy path: client trusts the CA and the hostname matches -> handshake
    # succeeds, peer verifies, and the encrypted echo round-trips.
    def test_roundtrip_and_peer_verified() {
        const th: Thread = Thread(server_valid)
        th.start()

        const ctx: SSLContext = SSLContext(PROTOCOL_TLS_CLIENT)
        ctx.load_verify_locations(ca_file, "")
        const raw: TcpStream = TcpStream.open("127.0.0.1", PORT)
        const s: SSLSocket = ctx.wrap_socket(raw, False, "localhost")
        s.send("ping")
        const resp: bytes = s.recv(4096)
        self.assertEqual(resp.decode("utf-8"), SERVER_REPLY)
        self.assertTrue(s.getpeer_verified())
        s.close()
        th.join()
    }

    # Untrusted chain: client has no CA in its store -> verification fails.
    def test_untrusted_chain_rejected() {
        const th: Thread = Thread(server_valid)
        th.start()
        self.assertRaises(SSLCertVerificationError, lambda () -> None {
            const ctx: SSLContext = SSLContext(PROTOCOL_TLS_CLIENT)
            const raw: TcpStream = TcpStream.open("127.0.0.1", PORT)
            ctx.wrap_socket(raw, False, "localhost")
        })
        th.join()
    }

    # Hostname mismatch: CA is trusted, but the requested name is not in the
    # cert's SAN -> verification fails (RFC 6125).
    def test_hostname_mismatch_rejected() {
        const th: Thread = Thread(server_valid)
        th.start()
        self.assertRaises(SSLCertVerificationError, lambda () -> None {
            const ctx: SSLContext = SSLContext(PROTOCOL_TLS_CLIENT)
            ctx.load_verify_locations(ca_file, "")
            const raw: TcpStream = TcpStream.open("127.0.0.1", PORT)
            ctx.wrap_socket(raw, False, "wrong.example.com")
        })
        th.join()
    }

    # Expired leaf: CA is trusted and the hostname matches, but the cert's
    # validity window is in the past -> verification fails.
    def test_expired_cert_rejected() {
        const th: Thread = Thread(server_expired)
        th.start()
        self.assertRaises(SSLCertVerificationError, lambda () -> None {
            const ctx: SSLContext = SSLContext(PROTOCOL_TLS_CLIENT)
            ctx.load_verify_locations(ca_file, "")
            const raw: TcpStream = TcpStream.open("127.0.0.1", PORT)
            ctx.wrap_socket(raw, False, "localhost")
        })
        th.join()
    }

    # R1: after a successful handshake the client sends nothing; the server's
    # do_recv_timeout(300) must fire (~300ms) with an empty result rather than
    # blocking forever - the encrypted-path slowloris defense.
    def test_recv_timeout_on_silent_peer() {
        const th: Thread = Thread(server_recv_timeout)
        th.start()
        const ctx: SSLContext = SSLContext(PROTOCOL_TLS_CLIENT)
        ctx.load_verify_locations(ca_file, "")
        const raw: TcpStream = TcpStream.open("127.0.0.1", PORT)
        const s: SSLSocket = ctx.wrap_socket(raw, False, "localhost")
        # Handshake complete; deliberately send NOTHING and keep the socket open
        # while the server waits, so the server's read times out (not EOF).
        th.join()
        s.close()
        self.assertTrue(g_probe.timed_out)
        self.assertTrue(g_probe.elapsed_ms >= 150.0)   # actually waited
        self.assertTrue(g_probe.elapsed_ms < 3000.0)   # but did fire
    }
}


main([TlsLoopbackTests()])
