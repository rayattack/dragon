# test/dr/test_http_gzip.dr - W6 response compression (gzip) gate.
#
# Drives the server with an in-memory ConnReader (MemoryReader) - no sockets.
# The body-compression byte-exactness of the dragon_str_from_bytes bridge is
# proven separately; here we test the negotiation GATE end-to-end through
# serialize(): compress iff the client advertised gzip AND the content-type is
# compressible AND the body clears _GZIP_MIN_BODY (1400) AND it isn't already
# encoded. Correctness signal: when compression fires, the distinctive plaintext
# marker must be ABSENT from the wire bytes (it was deflated); when it doesn't,
# the marker is present verbatim.

from unittest import TestCase, main
from http.server import Router, Request, Response, Context
from http.server import MemoryReader

const MARKER: str = "DRAGON_GZIP_MARKER_"

# ~3800 bytes of text/plain (compressible, well over the 1400-byte floor).
def _big(req: Request, res: Response, ctx: Context) -> None {
    res.text(MARKER * 200)
}

# Tiny body - below the floor, must never be compressed.
def _small(req: Request, res: Response, ctx: Context) -> None {
    res.text("hi")
}

# Large but already-compressed content-type - must not be re-compressed.
def _png(req: Request, res: Response, ctx: Context) -> None {
    res.text(MARKER * 200)
    res.set_header("content-type", "image/png")   # after text() - text() forces text/plain
}

def _app() -> Router {
    const app: Router = Router(0)
    app.GET("/big", _big)
    app.GET("/small", _small)
    app.GET("/png", _png)
    return app
}

def _req(path: str, accept_gzip: bool) -> bytes {
    enc: str = "Accept-Encoding: gzip\r\n" if accept_gzip else ""
    const head: str = "GET " + path + " HTTP/1.1\r\nHost: h\r\n" + enc + "Connection: close\r\n\r\n"
    return head.encode("utf-8")
}

class GzipGateTests(TestCase) {
    # Large compressible body + Accept-Encoding: gzip -> compressed.
    def test_compresses_large_text() {
        const mr: MemoryReader = MemoryReader([_req("/big", true)])
        _app().serve_connection(mr)
        self.assertIn("content-encoding: gzip", mr.sent)
        self.assertIn("vary: Accept-Encoding", mr.sent)
        # Deflated: the plaintext marker must not survive on the wire.
        self.assertNotIn(MARKER, mr.sent)
    }

    # Same body, no Accept-Encoding -> sent verbatim, no encoding header.
    def test_no_accept_encoding_uncompressed() {
        const mr: MemoryReader = MemoryReader([_req("/big", false)])
        _app().serve_connection(mr)
        self.assertNotIn("content-encoding: gzip", mr.sent)
        self.assertIn(MARKER, mr.sent)
    }

    # Body below _GZIP_MIN_BODY -> not compressed even with gzip offered.
    def test_small_body_not_compressed() {
        const mr: MemoryReader = MemoryReader([_req("/small", true)])
        _app().serve_connection(mr)
        self.assertNotIn("content-encoding: gzip", mr.sent)
        self.assertIn("hi", mr.sent)
    }

    # Non-compressible content-type -> left alone even when large + gzip offered.
    def test_incompressible_type_skipped() {
        const mr: MemoryReader = MemoryReader([_req("/png", true)])
        _app().serve_connection(mr)
        self.assertNotIn("content-encoding: gzip", mr.sent)
        self.assertIn(MARKER, mr.sent)
    }
}

main([GzipGateTests()])
