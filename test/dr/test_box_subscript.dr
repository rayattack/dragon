# test/dr/test_box_subscript.dr - subscripting an Any/Union (box) value.
#
# Regression guard: `anyVal[index]` returned 0. The static type is
# `Any`, so codegen couldn't pick a typed subscript path; the receiver was a
# 16-byte box (not a pointer), so the SubscriptExpr fast path hit a
# `return constant 0` fallback. The fix boxes the index and routes through the
# runtime dragon_box_subscript, which dispatches on the receiver's runtime tag
# (list / dict / str / bytes) and returns a result box - preserving the
# element's tag for downstream print / isinstance / unbox-on-assign.

from unittest import TestCase, main


class BoxSubscriptTests(TestCase) {
    def test_int_list_index() {
        # The original repro.
        a: Any = [10, 20, 30]
        self.assertEqual(a[0], 10)
        self.assertEqual(a[1], 20)
        self.assertEqual(a[2], 30)
    }

    def test_negative_index() {
        a: Any = [10, 20, 30]
        self.assertEqual(a[-1], 30)
        self.assertEqual(a[-3], 10)
    }

    def test_float_list_index() {
        b: Any = [1.5, 2.5, 3.5]
        self.assertEqual(b[1], 2.5)
    }

    def test_bool_list_index() {
        bl: Any = [True, False, True]
        self.assertEqual(bl[0], True)
        self.assertEqual(bl[1], False)
    }

    def test_str_list_index() {
        c: Any = ["x", "y", "z"]
        self.assertEqual(c[2], "z")
    }

    def test_nested_list_index() {
        d: Any = [[1, 2], [3, 4]]
        self.assertEqual(d[1], [3, 4])
    }

    def test_str_keyed_dict() {
        m: Any = {"name": "Ada", "age": 42}
        self.assertEqual(m["name"], "Ada")
        self.assertEqual(m["age"], 42)
    }

    def test_int_keyed_dict() {
        n: Any = {1: "one", 2: "two"}
        self.assertEqual(n[1], "one")
        self.assertEqual(n[2], "two")
    }

    def test_string_index() {
        s: Any = "hello"
        self.assertEqual(s[1], "e")
        self.assertEqual(s[-1], "o")
    }

    def test_unbox_into_typed_slot() {
        a: Any = [10, 20, 30]
        x: int = a[1]
        self.assertEqual(x, 20)
        self.assertEqual(x + 5, 25)
    }

    def test_unbox_str_into_typed_slot() {
        m: Any = {"name": "Ada"}
        nm: str = m["name"]
        self.assertEqual(nm.upper(), "ADA")
    }

    def test_chained_subscript() {
        obj: Any = {"b": [4, 5, 6]}
        self.assertEqual(obj["b"][2], 6)
    }

    def test_index_out_of_range_raises() {
        a: Any = [1, 2, 3]
        raised: bool = False
        try {
            print(a[10])
        } except IndexError {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_missing_dict_key_raises() {
        m: Any = {"x": 1}
        raised: bool = False
        try {
            print(m["y"])
        } except KeyError {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_not_subscriptable_raises() {
        a: Any = 5
        raised: bool = False
        try {
            print(a[0])
        } except TypeError {
            raised = True
        }
        self.assertTrue(raised)
    }

    def test_wrong_index_type_raises() {
        a: Any = [1, 2, 3]
        k: Any = "x"
        raised: bool = False
        try {
            print(a[k])
        } except TypeError {
            raised = True
        }
        self.assertTrue(raised)
    }
}


main([BoxSubscriptTests()])
