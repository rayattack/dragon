# test/dr/test_listany_subscript_store.dr - subscript STORE into a list[Any].
#
# Regression guard for a silent miscompile: `xs[i] = v` on a list[Any] was
# lowered to dragon_list_set (the 8-byte DragonList setter) even though a
# list[Any] is a DragonListBox with 16-byte {tag,payload} elements. The store
# either silently no-op'd (the slot kept its OLD value) or wrote a corrupt box
# (`<box tag=... payload=...>`). The fix routes list[Any] subscript stores to
# dragon_list_box_set, boxing the RHS via boxArgTagPayload (which increfs a
# borrowed source so the list's owned ref outlives it; box_set decrefs the
# overwritten element). list[int]/list[str]/... stores were never affected.
#
# These assertions FAIL (wrong value) or crash on the pre-fix compiler.

from unittest import TestCase, main


class ListAnySubscriptStoreTests(TestCase) {
    def test_store_scalar_then_read() {
        xs: list[Any] = [0, 0, 0]
        xs[0] = 42
        xs[1] = "hi"
        xs[2] = True
        self.assertEqual(xs[0], 42)
        self.assertEqual(xs[1], "hi")
        self.assertEqual(xs[2], True)
    }

    def test_store_overwrites_old_value() {
        # The pre-fix bug kept the OLD value on overwrite - this is the exact
        # `anys[1] = "TWO"` -> still "two" repro.
        anys: list[Any] = [1, "two", 3]
        anys[1] = "TWO"
        self.assertEqual(anys[1], "TWO")
    }

    def test_store_heap_element() {
        xs: list[Any] = [0, 0]
        xs[0] = [9, 8]
        xs[1] = "z"
        self.assertEqual(xs[0], [9, 8])
        self.assertEqual(xs[1], "z")
    }

    def test_overwrite_heap_with_other_type() {
        # Overwriting a heap element (list) with a str exercises box_set's
        # decref-of-old path; must not corrupt or leak.
        xs: list[Any] = [[1, 2, 3]]
        xs[0] = "done"
        self.assertEqual(xs[0], "done")
        # And overwrite str -> list back again.
        xs[0] = [4, 5]
        self.assertEqual(xs[0], [4, 5])
    }

    def test_negative_index_store() {
        xs: list[Any] = [1, 2, 3]
        xs[-1] = "last"
        self.assertEqual(xs[-1], "last")
        self.assertEqual(xs[2], "last")
    }
}


main([ListAnySubscriptStoreTests()])
