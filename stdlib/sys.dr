# sys.dr - Dragon standard library: system-specific parameters and functions
#
# Provides process exit, platform info, and system limits.

#===----------------------------------------------------------------------===#
# C extern declarations
#===----------------------------------------------------------------------===#

extern "C" def exit(status: intc) as _libc_exit
extern "C" def abort()
extern "C" def getenv(name: str) -> str
extern "C" def dragon_argv_count() -> int
extern "C" def dragon_argv_at(i: int) -> str

#===----------------------------------------------------------------------===#
# Constants
#===----------------------------------------------------------------------===#

const maxsize: int = 9223372036854775807
const platform: str = "linux"
const byteorder: str = "little"
const version: str = "0.1.0"

#===----------------------------------------------------------------------===#
# System functions
#===----------------------------------------------------------------------===#

def exit(code: int) {
    _libc_exit(code)
}

def abort_now() {
    abort()
}

def getdefaultencoding() -> str {
    return "utf-8"
}

def getrecursionlimit() -> int {
    return 1000
}

def argv() -> list[str] {
    # Process argv as a list: [executable, arg1, arg2, ...].
    const result: list[str] = []
    const n: int = dragon_argv_count()
    for i in range(n) {
        result.append(dragon_argv_at(i))
    }
    return result
}
